# Copy to `.env` and/or `.env.local` (API loads `.env` then `.env.local` with override — see docs/LOCAL_DEV.md).
#
# --- Auth0 BFF (server/index.mjs + server/bff/*) — confidential app with client secret ---
# In Auth0: create a "Regular Web Application" (or Native) with client secret — not a public SPA-only app.
# Allowed Callback URLs: http://localhost:5173/api/auth/callback (Vite proxies /api → :3000)
# Allowed Logout URLs: http://localhost:5173
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID="your_client_id"
AUTH0_CLIENT_SECRET="your_client_secret"
# Must match a URL Auth0 accepts; use the Vite origin so the browser stays on :5173
AUTH0_CALLBACK_URL="http://localhost:5173/api/auth/callback"
# After Auth0 /v2/logout — must EXACTLY match an entry in Auth0 "Allowed Logout URLs" (www vs non-www matters).
# If unset, the API uses AUTH0_CALLBACK_URL origin (e.g. https://mybuffer.ca from https://mybuffer.ca/api/auth/callback).
# Set explicitly if your users hit www but Auth0 only allows www (or vice versa):
# AUTH0_LOGOUT_RETURN_URL="https://www.mybuffer.ca"
# Back-compat alias also supported by this app:
# LOGOUT_REDIRECT_URL="https://www.mybuffer.ca"
# Optional: Auth0 API identifier for access tokens (userinfo + refresh)
# AUTH0_AUDIENCE="https://your-api-identifier"

# Account deletion + M2M: use canonical tenant host if login uses a custom domain
# AUTH0_MGMT_DOMAIN="dev-xxxx.us.auth0.com"
# AUTH0_MGMT_CLIENT_ID="..."
# AUTH0_MGMT_CLIENT_SECRET="..."

# Browser never needs VITE_AUTH0_* — tokens live only on the server.

# --- Dashboard (Vite client) — optional ---
# Default is pre (Plaid connect) until the server reports Plaid connected.
# Set post to force post-connection UI without Plaid (demo / design only).
# Override per session: ?dashboardConnection=pre|post on any /dashboard route.
# VITE_DASHBOARD_CONNECTION=post

# --- Plaid (Phase 1+ — server/bff/registerPlaid.mjs) ---
# Never commit real secrets. Sandbox: https://dashboard.plaid.com
# PLAID_CLIENT_ID="..."
# PLAID_SECRET="..."           # development / production secret
# PLAID_SANDBOX_SECRET="..."   # optional: when PLAID_ENV=sandbox, preferred over PLAID_SECRET (handy in .env.local)
# PLAID_ENV="sandbox"
# Optional; include CA Link + webhooks in production
# PLAID_WEBHOOK_URL="https://api.mybuffer.ca/webhooks/plaid"
# 32-byte key, base64 — encrypts access tokens at rest (openssl rand -base64 32)
# PLAID_ACCESS_TOKEN_ENCRYPTION_KEY="..."

DATABASE_URL="postgres://YOUR_ACCELERATE_OR_POOLED_URL_HERE"
DIRECT_URL="postgres://YOUR_DIRECT_URL_HERE"
