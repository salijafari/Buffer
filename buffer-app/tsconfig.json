{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "strict":           true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess":   true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "isolatedModules":  true,
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true
  },
  "exclude": ["node_modules", "**/dist", "**/.next"]
}
